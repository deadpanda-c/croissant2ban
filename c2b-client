#!/usr/bin/env python3
import json
import re
import subprocess
import sys

CONFIG_FILE = "conf/croissant.json"


def get_enabled_services():
    """Reads the JSON config to see what is currently enabled."""
    try:
        with open(CONFIG_FILE, "r") as f:
            config = json.load(f)
        services = config.get("services", {})
        print(f"{'SERVICE':<10} | {'PORT':<6} | {'STATUS':<8} | {'LOGPATH'}")
        print("-" * 60)
        for name, info in services.items():
            status = "ENABLED" if info.get("enabled") else "DISABLED"
            path = info.get("logpath", "N/A")
            print(f"{name:<10} | {info.get('port'):<6} | {status:<8} | {path}")
    except FileNotFoundError:
        print(f"Error: Config file not found at '{CONFIG_FILE}'")
    except json.JSONDecodeError as e:
        print(f"Error: Failed to parse config: {e}")


def get_banned_ips():
    """Queries iptables to find IPs currently blocked by the system."""
    try:
        result = subprocess.run(
            ["sudo", "iptables", "-L", "INPUT", "-n"],
            capture_output=True,
            text=True,
            check=True,
        )

        print(f"\n{'IP ADDRESS':<18} | {'REASON'}")
        print("-" * 40)

        lines = result.stdout.splitlines()
        found = False
        for line in lines:
            if "DROP" not in line:
                continue
            parts = line.split()
            if len(parts) < 4:
                continue
            ip = parts[3]
            if ip in ("0.0.0.0/0", "anywhere", "::/0"):
                continue
            print(f"{ip:<18} | Croissant2Ban")
            found = True

        if not found:
            print("No active bans found.")

    except subprocess.CalledProcessError as e:
        print(f"Error fetching bans (is sudo available?): {e}")
    except FileNotFoundError:
        print(
            "Error: iptables not found. Are you running on a Linux system with root access?"
        )


_IP_RE = re.compile(
    r"^(\d{1,3}\.){3}\d{1,3}$"
)  # Simple regex to check basic IPv4 format (4 octets, 0-255)


def is_valid_ipv4(ip: str) -> bool:
    if not _IP_RE.match(ip):
        return False
    return all(0 <= int(part) <= 255 for part in ip.split("."))


def manual_unban(ip: str):
    if not is_valid_ipv4(ip):
        print(f"Error: '{ip}' is not a valid IPv4 address.")
        sys.exit(1)
    try:
        subprocess.run(
            ["sudo", "iptables", "-D", "INPUT", "-s", ip, "-j", "DROP"],
            capture_output=True,
            text=True,
            check=True,
        )
        print(f"[OK] {ip} has been removed from the blocklist.")
        print(
            "Note: if croissant2ban is running, it will sync this change within ~30 seconds."
        )
    except subprocess.CalledProcessError as e:
        # iptables exits 1 with "Bad rule" when the rule doesn't exist
        if "Bad rule" in e.stderr or "No chain/target/match" in e.stderr:
            print(
                f"Warning: No active ban found for {ip} (may have already been removed)."
            )
        else:
            print(f"Error: iptables command failed: {e.stderr.strip()}")


def show_help():
    print("""
Croissant2Ban Client Control
Usage: ./c2b-client.py [command]

Commands:
  services    List all services and their current config status
  banned      List all IPs currently blocked in iptables
  unban <IP>  Manually remove an IP from the blocklist
  help        Show this menu
    """)


if __name__ == "__main__":
    if len(sys.argv) < 2:
        show_help()
        sys.exit(0)

    cmd = sys.argv[1].lower()

    if cmd == "services":
        get_enabled_services()
    elif cmd == "banned":
        get_banned_ips()
    elif cmd == "unban":
        if len(sys.argv) < 3:
            print("Error: Please provide an IP to unban.")
            sys.exit(1)
        manual_unban(sys.argv[2])
    elif cmd == "help":
        show_help()
    else:
        print(f"Unknown command: '{cmd}'")
        show_help()
        sys.exit(1)
